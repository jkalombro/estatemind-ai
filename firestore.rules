rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: properties
    // Fields: title, description, price, location, type, images, agentId, createdAt
    //
    // Collection: faqs
    // Fields: question, answer, agentId, createdAt
    //
    // Collection: settings
    // Fields: chatbotName, welcomeMessage, agentId
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "jkninja238@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isNotBlocked() {
      return isAuthenticated() && 
             (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) == false);
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && (resource.data.get('agentId', '') == request.auth.uid || isAdmin());
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.get('role', '') == resource.data.get('role', ''));
      allow delete: if isAdmin();
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBlocked();
      allow update, delete: if isDocOwner() && isNotBlocked();
    }

    match /faqs/{faqId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBlocked();
      allow update, delete: if isDocOwner() && isNotBlocked();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if (isOwner(settingId) && isNotBlocked()) || isAdmin();
    }

    match /conversations/{conversationId} {
      allow read: if isAdmin() || (isAuthenticated() && isNotBlocked() && (resource == null || resource.data.get('agentId', '') == request.auth.uid));
      allow create: if true;
      allow update: if true; // Allow chatbot and agent updates
      allow delete: if isAdmin() || (isAuthenticated() && isNotBlocked() && resource.data.get('agentId', '') == request.auth.uid);
    }

    match /messages/{messageId} {
      allow read: if isAdmin() || (isAuthenticated() && isNotBlocked() && resource.data.get('agentId', '') == request.auth.uid);
      allow create: if true;
      allow delete: if isAdmin() || (isAuthenticated() && isNotBlocked() && resource.data.get('agentId', '') == request.auth.uid);
    }
    
    match /_connection_test/{testId} {
      allow read: if true;
    }
  }
}
